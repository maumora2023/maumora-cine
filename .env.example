VITE_FIREBASE_API_KEY=tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_project_id
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
VITE_FIREBASE_APP_ID=tu_app_id
VITE_WEB_STREAM_PROXY_URL=https://tu-servicio-render.onrender.com/stream

# API externa de catalogo. Si no se configura, se usa la fuente actual.
STREAMFLIX_API_BASE_URL=https://tu-api.com
STREAMFLIX_API_TOKEN=
STREAMFLIX_MOVIES_ENDPOINT=/movies
STREAMFLIX_SERIES_ENDPOINT=/series
STREAMFLIX_ANIME_ENDPOINT=/anime
# Opcional. Si no existe, el home se arma con peliculas/series/anime.
STREAMFLIX_HOME_ENDPOINT=

# Agenda OnlineFutbol. La clave real va en .env, no en archivos publicos.
OFUTBOL_API_TOKEN=
OFUTBOL_API_ORIGIN=https://maumoracine.web.app
OFUTBOL_MIRROR_DIR=C:/Users/Maumora/Desktop/2/ofutbol.jdoxx.com
